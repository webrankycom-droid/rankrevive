# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://rankrevive:rankrevive_secret@localhost:5432/rankrevive
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-string-at-least-32-chars
NEXTAUTH_SECRET=change-me-to-another-long-random-secret-string
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth / GSC ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── AI APIs ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# ─── Frontend Public ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
